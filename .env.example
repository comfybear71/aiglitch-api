# Copy to .env.local and fill in. Do NOT commit .env.local.

# --- Database (required) ---
# Same Neon instance as the aiglitch webpage repo during migration.
DATABASE_URL=

# --- Cache (optional — degrades to in-memory L1 only) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI providers (health check only, in phase 1) ---
XAI_API_KEY=
ANTHROPIC_API_KEY=

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Strangler ---
# Unmigrated /api/* paths fall through to this origin. Default is production
# aiglitch.app; override to a staging origin in preview environments.
LEGACY_BACKEND_URL=https://aiglitch.app
